FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml ./
COPY app ./app
COPY alembic.ini ./
COPY alembic ./alembic

RUN pip install --no-cache-dir .

EXPOSE 8000

CMD ["sh", "-c", "python -m app.db.reset_database && alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --log-level info --access-log"]
